{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "INNER arm — harness runs sidecar validation after each agent turn (see run-trial.sh). No Stop hook: claude -p does not reliably block/resume on hooks.",
  "permissions": {
    "allow": [
      "Bash(chunk sidecar sync:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(chunk validate*)",
      "Bash(git add .claude*)",
      "Bash(git add:.claude*)",
      "Bash(git commit * .claude*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(jest *)",
      "Bash(eslint *)"
    ]
  }
}
